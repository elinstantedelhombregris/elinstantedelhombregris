{
  "name": "@v2/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Cross-cutting Zod schemas, types, and content registries.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./validation": "./src/validation/index.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test:unit": "vitest run src/ --passWithNoTests",
    "test:integration": "echo 'no integration tests' && exit 0"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@v2/config-eslint": "workspace:*",
    "@v2/config-typescript": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
