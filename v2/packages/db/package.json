{
  "name": "@v2/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Drizzle schemas, migrations, and repositories for v2.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests || true"
  },
  "dependencies": {},
  "devDependencies": {
    "@v2/config-eslint": "workspace:*",
    "@v2/config-typescript": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
