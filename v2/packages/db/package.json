{
  "name": "@v2/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Drizzle schemas, migrations, and repositories for v2.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "test:unit": "vitest run src/ --passWithNoTests",
    "test:integration": "vitest run --dir tests || true"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@v2/config-eslint": "workspace:*",
    "@v2/config-typescript": "workspace:*",
    "@v2/shared": "workspace:*",
    "drizzle-kit": "^0.30.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
