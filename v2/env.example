# =============================================================================
# v2 environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Database (Neon Postgres)
# -----------------------------------------------------------------------------
# Production / dev pooled connection
DATABASE_URL=postgres://user:password@host/db?sslmode=require
# Direct (non-pooled) connection — required for migrations
DATABASE_URL_UNPOOLED=postgres://user:password@host/db?sslmode=require

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# 64+ random hex characters; rotate on incident
JWT_SECRET=change-me-to-a-long-random-hex-string
SESSION_SECRET=change-me-to-a-different-long-random-hex-string
# Cookie domain (e.g. .elinstantedelhombregris.com); leave blank for localhost
COOKIE_DOMAIN=
COOKIE_SECURE=false   # true in production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=hola@elinstantedelhombregris.com

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info   # debug | info | warn | error
