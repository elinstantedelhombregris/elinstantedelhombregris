{
  "version": 2,
  "installCommand": "cd SocialJusticeHub && npm install",
  "buildCommand": "cd SocialJusticeHub && npm run build",
  "outputDirectory": "SocialJusticeHub/dist/public",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

