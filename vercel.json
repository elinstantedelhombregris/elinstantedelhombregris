{
  "version": 2,
  "installCommand": "cd SocialJusticeHub && npm install",
  "buildCommand": "cd SocialJusticeHub && npm run build",
  "outputDirectory": "SocialJusticeHub/dist/public",
  "framework": null,
  "functions": {
    "SocialJusticeHub/api/index.mjs": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "SocialJusticeHub/api/index.mjs?path=$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

