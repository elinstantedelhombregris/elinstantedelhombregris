{
  "expo": {
    "name": "¡BASTA!",
    "slug": "basta-juego",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bastajuego",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "ios": {
      "bundleIdentifier": "ar.basta.juego",
      "supportsTablet": false,
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tu ubicación le da lugar a cada estrella que encendés. Nunca sale de tu teléfono.",
        "NSCameraUsageDescription": "La cámara es para capturar lo que ves y escanear chispas de otras personas."
      }
    },
    "android": {
      "package": "ar.basta.juego",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tu ubicación le da lugar a cada estrella que encendés. Nunca sale de tu teléfono."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "La cámara es para capturar lo que ves y escanear chispas de otras personas."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "cielo"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
